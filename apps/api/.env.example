# Local PostgreSQL (docker compose up -d postgres from repo root).
# Port 15432 avoids conflicts with an existing Postgres on :5432/:5433.
DATABASE_URL="postgresql://spt:spt@localhost:15432/spt_dev"
DIRECT_URL="postgresql://spt:spt@localhost:15432/spt_dev"

# Production (Supabase) — use on Railway only:
# DATABASE_URL → transaction pooler :6543?pgbouncer=true&connection_limit=3
# DIRECT_URL   → session pooler :5432 (prisma migrate)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=3&pool_timeout=20&connect_timeout=15"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_EXPIRES_IN="7d"

# AES-256 key for encrypting OAuth tokens at rest (32 bytes, base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY="change-me-run-node-crypto-randomBytes-32-base64"

# App URLs
API_URL="http://localhost:3000"
WEB_URL="http://localhost:5173"

# OAuth — VK (user login + future wall posts; service token for public groups)
# Create a Standalone app at https://vk.com/editapp?act=create
# Redirect URI: VK_CALLBACK_URL below
# Scopes: email, offline, groups, wall, photos
VK_APP_ID=""
VK_APP_SECRET=""
VK_CALLBACK_URL="http://localhost:3000/api/oauth/vk/callback"
# Service token for public group metrics without user OAuth
VK_SERVICE_TOKEN=""

# YouTube Data API — video metrics and public channel subscriber counts
# Enable "YouTube Data API v3" in Google Cloud Console → Credentials → API key
YOUTUBE_API_KEY=""

# OAuth — Instagram (via Meta / Facebook Login for Business)
# Requirements: Instagram Business or Creator account linked to a Facebook Page.
# 1. Create app at https://developers.facebook.com/apps/
# 2. Add products: Facebook Login + Instagram
# 3. Set Valid OAuth Redirect URI to FACEBOOK_CALLBACK_URL below
# 4. Request permissions: instagram_basic, instagram_manage_insights,
#    pages_show_list, pages_read_engagement
# FACEBOOK_APP_ID=""
# FACEBOOK_APP_SECRET=""
# FACEBOOK_CALLBACK_URL="http://localhost:3000/api/oauth/facebook/callback"

# Telegram Bot API — subscriber counts via user-provided bot token
# Optional. Omit on a foreign VPS where api.telegram.org is reachable directly.
# Local dev (blocked networks): HTTP or SOCKS5 proxy on the API server:
# TELEGRAM_API_PROXY="http://127.0.0.1:7890"
# TELEGRAM_API_PROXY="socks5://127.0.0.1:1080"
# TELEGRAM_API_PROXY="socks5://user:pass@proxy.example.com:1080"
# Alternative: local telegram-bot-api + TELEGRAM_API_BASE="http://127.0.0.1:8081/bot"
